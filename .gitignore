# =============================================================================
# LUMINA MENTAL HEALTH AI — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Variáveis de ambiente e segredos
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
/.next/
/out/
src/web/.next/
next-env.d.ts

# -----------------------------------------------------------------------------
# Node.js
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Python (serviço de IA)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
.Python
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# -----------------------------------------------------------------------------
# Testes e cobertura
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
lcov.info
*.lcov

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
audit-logs/

# -----------------------------------------------------------------------------
# Banco de dados local
# -----------------------------------------------------------------------------
*.sqlite3
*.db
/data/local/

# -----------------------------------------------------------------------------
# Certificados e chaves
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.p12

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
.vercel
.turbo
