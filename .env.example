# =============================================================================
# LUMINA MENTAL HEALTH AI — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite o arquivo .env.local no repositório
# =============================================================================

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------

# URL de conexão com PostgreSQL (inclui pgvector)
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://lumina_user:change_me@localhost:5432/lumina_db

# URL de conexão com Redis (cache, sessões e filas)
# Formato: redis://host:porta
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# AUTENTICAÇÃO E SEGURANÇA
# -----------------------------------------------------------------------------

# Chave secreta para assinatura de JWT de acesso (mínimo 256 bits)
# Gere com: openssl rand -base64 32
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32

# Chave secreta para assinatura de JWT de refresh (diferente do JWT_SECRET)
JWT_REFRESH_SECRET=change_me_generate_different_secret_for_refresh

# Segredo para NextAuth.js (autenticação web)
NEXTAUTH_SECRET=change_me_nextauth_secret

# URL base da aplicação (sem barra no final)
NEXTAUTH_URL=http://localhost:3000

# Chave de criptografia para dados sensíveis em repouso (AES-256, 32 bytes hex)
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=change_me_hex_32_bytes_for_aes256_encryption

# -----------------------------------------------------------------------------
# SERVIÇO DE INTELIGÊNCIA ARTIFICIAL
# -----------------------------------------------------------------------------

# URL base do serviço de IA (LLM + análise clínica)
AI_SERVICE_URL=http://localhost:8000

# Chave de API para autenticação no serviço de IA
AI_SERVICE_API_KEY=change_me_ai_service_api_key

# -----------------------------------------------------------------------------
# LOGS E AUDITORIA
# -----------------------------------------------------------------------------

# Habilita log de auditoria de acesso a dados clínicos (true/false)
AUDIT_LOG_ENABLED=true

# -----------------------------------------------------------------------------
# AMBIENTE
# -----------------------------------------------------------------------------

# Ambiente de execução: development | test | production
NODE_ENV=development
